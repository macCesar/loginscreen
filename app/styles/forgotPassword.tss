/* ── ForgotPassword: screen-specific overrides ── */

"#content": {
	width: "85%",
	height: Ti.UI.SIZE,
	layout: "vertical",
	center: { y: "42%" },
	opacity: 0
}

"#emailGroup": {
	top: 32
}

"#loader": {
	top: 16,
	visible: false
}

"#confirmation": {
	width: "85%",
	height: Ti.UI.SIZE,
	layout: "vertical",
	center: { y: "42%" },
	visible: false,
	opacity: 0
}

"#backToLoginBtn": {
	width: "100%"
}
