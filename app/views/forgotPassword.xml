<Alloy>
  <Window id="win">
		<View id="bgTop" class="bgTop"/>
		<View id="bgBottom" class="bgBottom"/>

		<View class="header">
			<Label id="backBtn" class="backBtn" onClick="goBack">← Back</Label>
		</View>

    <View id="content">
      <Label class="screenIcon">🔑</Label>
			<Label id="screenTitle" class="screenTitle">Forgot Password?</Label>
			<Label id="screenSubtitle" class="screenSubtitle">Enter your email and we'll send you a link to reset your password.</Label>

      <View id="emailGroup" class="fieldGroup">
				<Label id="emailLabel" class="fieldLabel">Email</Label>
        <TextField id="emailField" class="field" hintText="you@example.com" keyboardType="Ti.UI.KEYBOARD_TYPE_EMAIL" autofillType="Ti.UI.AUTOFILL_TYPE_EMAIL" autocapitalization="Ti.UI.TEXT_AUTOCAPITALIZATION_NONE" autocorrect="false" returnKeyType="Ti.UI.RETURNKEY_DONE" onReturn="doSend" onChange="validateEmail"/>
        <View id="emailUnderline" class="underline"/>
        <Label id="emailError" class="fieldError">Please enter a valid email address</Label>
      </View>

      <View id="sendBtn" class="primaryBtn" onClick="doSend">
        <Label id="sendBtnLabel" class="primaryBtnLabel">Send Reset Link</Label>
      </View>
      <ActivityIndicator id="loader" visible="false"/>
    </View>

    <!-- Confirmation (hidden by default) -->
    <View id="confirmation" visible="false">
      <Label class="screenIcon">✉️</Label>
			<Label id="confirmationTitle" class="screenTitle">Check Your Email</Label>
			<Label id="confirmationSubtitle" class="screenSubtitle">We've sent a password reset link to your email address.</Label>
      <View id="backToLoginBtn" class="primaryBtn" onClick="goBack">
        <Label class="primaryBtnLabel">Back to Login</Label>
      </View>
    </View>
  </Window>
</Alloy>
