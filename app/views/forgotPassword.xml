<Alloy>
  <Window id="win" class="bg-app">
    <Animation id="contentEntrance" module="purgetss.ui" class="opacity-to-100 duration-500 ease-out"/>
    <Animation id="buttonPressAnim" module="purgetss.ui" class="close:opacity-100 duration-100 ease-out open:opacity-80"/>
    <Animation id="shakeAnim" module="purgetss.ui" class="duration-75 ease-out"/>

    <View id="bgTop" class="bgTop"/>

    <View class="header">
      <Label id="backBtn" class="backBtn" accessibilityLabel="Back button" accessibilityHint="Return to login screen" onClick="goBack">← Back</Label>
    </View>

    <View id="content" class="auth-content top-1/4">
      <Label class="screenIcon">🔑</Label>
      <Label id="screenTitle" class="screenTitle">Forgot Password?</Label>
      <Label id="screenSubtitle" class="screenSubtitle">Enter your email and we'll send you a link to reset your password.</Label>

      <View id="emailGroup" class="fieldGroup mt-8">
        <Label id="emailLabel" class="fieldLabel">Email</Label>
        <TextField id="emailField" class="field keyboard-type-email autofill-type-email autocorrect-false return-key-type-done normal-case" accessibilityLabel="Email address field" accessibilityHint="Enter your email to receive a password reset link" hintText="you@example.com" onReturn="doSend" onChange="validateEmail"/>
        <View id="emailUnderline" class="underline"/>
        <Label id="emailError" class="fieldError">Please enter a valid email address</Label>
      </View>

      <View id="sendBtn" class="primaryBtn" accessibilityLabel="Send reset link button" accessibilityHint="Tap to send a password reset link to your email" onTouchstart="openButton" onTouchend="closeButton" onTouchcancel="closeButton" onClick="doSend">
        <Label id="sendBtnLabel" class="primaryBtnLabel">Send Reset Link</Label>
      </View>
      <ActivityIndicator id="loader" class="mt-4 hidden"/>
    </View>

    <View id="confirmation" class="auth-content top-1/4 hidden">
      <Label class="screenIcon">✉️</Label>
      <Label id="confirmationTitle" class="screenTitle">Check Your Email</Label>
      <Label id="confirmationSubtitle" class="screenSubtitle">We've sent a password reset link to your email address.</Label>
      <View id="backToLoginBtn" class="primaryBtn" accessibilityLabel="Back to login button" accessibilityHint="Tap to return to the login screen" onTouchstart="openButton" onTouchend="closeButton" onTouchcancel="closeButton" onClick="goBack">
        <Label class="primaryBtnLabel">Back to Login</Label>
      </View>
    </View>
  </Window>
</Alloy>
