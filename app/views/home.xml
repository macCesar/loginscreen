<Alloy>
  <Window id="win" class="bg-app">
    <Animation id="contentEntrance" module="purgetss.ui" class="opacity-to-100 duration-500 ease-out"/>
    <Animation id="buttonPressAnim" module="purgetss.ui" class="close:opacity-100 duration-100 ease-out open:opacity-80"/>

    <View id="bgTop" class="bgTop"/>

    <View id="content" class="vertical top-3/12 h-auto w-screen opacity-0">
      <Label id="welcomeIcon" class="screenIcon text-(72)">🎉</Label>
      <Label id="welcomeTitle" class="screenTitle">Welcome!</Label>
      <Label id="welcomeText" class="text-app-muted touch-enabled-false mt-3 w-screen text-center text-base">You have successfully signed in.</Label>
      <Label id="sessionEmail" class="text-app-muted text-(13) touch-enabled-false mt-2 w-screen text-center"/>
      <Label id="sessionMeta" class="text-app-muted text-xs touch-enabled-false mt-1 w-screen text-center"/>

      <View id="logoutBtn" class="primaryBtn mx-10 mt-10" accessibilityLabel="Logout button" accessibilityHint="Tap to sign out of your account" onTouchstart="openButton" onTouchend="closeButton" onTouchcancel="closeButton" onClick="doLogout">
        <Label id="logoutBtnLabel" class="primaryBtnLabel">Sign Out</Label>
      </View>
    </View>
  </Window>
</Alloy>
