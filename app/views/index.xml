<Alloy>
  <Window id="win" class="bg-app">
    <Animation id="logoEntrance" module="purgetss.ui" class="opacity-to-100 duration-300 ease-out"/>
    <Animation id="cardEntrance" module="purgetss.ui" class="opacity-to-100 zoom-in-90 duration-200 ease-out"/>
    <Animation id="signupEntrance" module="purgetss.ui" class="opacity-to-100 duration-400 ease-out"/>
    <Animation id="buttonPressAnim" module="purgetss.ui" class="close:opacity-100 duration-100 ease-out open:opacity-80"/>
    <Animation id="shakeAnim" module="purgetss.ui" class="duration-75 ease-out"/>

    <View id="bgTop" class="bgTop"/>

    <View id="logoContainer" class="login-logo">
      <Label id="logoIcon" class="screenIcon">🔐</Label>
      <Label id="appTitle" class="text-app-text text-(28) touch-enabled-false mt-2 w-screen text-center font-bold">Welcome Back</Label>
      <Label id="appSubtitle" class="screenSubtitle">Sign in to continue</Label>
    </View>

    <View id="card" class="login-card">
      <View id="emailGroup" class="fieldGroup mx-5 mt-7">
        <Label id="emailLabel" class="fieldLabel">Email</Label>
        <TextField id="emailField" class="field keyboard-type-email autofill-type-username autocorrect-false return-key-type-next normal-case" accessibilityLabel="Email address field" accessibilityHint="Enter your email address to sign in" hintText="you@example.com" onReturn="focusPassword" onChange="validateEmail"/>
        <View id="emailUnderline" class="underline"/>
        <Label id="emailError" class="fieldError">Please enter a valid email address</Label>
      </View>

      <View id="passwordGroup" class="fieldGroup mx-5 mt-5">
        <Label id="passwordLabel" class="fieldLabel">Password</Label>
        <TextField id="passwordField" class="field password-mask autofill-type-password return-key-type-done" accessibilityLabel="Password field" accessibilityHint="Enter your password to sign in" hintText="Your password" onReturn="doLogin"/>
        <View id="passwordUnderline" class="underline"/>
        <Label id="passwordError" class="fieldError">Please enter your password</Label>
      </View>

      <Label id="forgotPassword" class="text-app-link mx-5 mt-3 h-auto w-screen text-right text-xs" accessibilityLabel="Forgot password link" accessibilityHint="Tap to reset your password" onClick="forgotTap">Forgot Password?</Label>

      <View id="loginBtn" class="primaryBtn mx-5" accessibilityLabel="Sign in button" accessibilityHint="Tap to sign in with your email and password" onTouchstart="openButton" onTouchend="closeButton" onTouchcancel="closeButton" onClick="doLogin">
        <Label id="loginBtnLabel" class="primaryBtnLabel">Sign In</Label>
      </View>

      <ActivityIndicator id="loader" class="hidden"/>
    </View>

    <View id="signupRow" class="signup-row">
      <Label id="signupText" class="text-app-muted text-(13) touch-enabled-false h-auto w-auto">Don't have an account? </Label>
      <Label id="signupLink" class="text-app-link text-(13) h-auto w-auto font-bold" accessibilityLabel="Sign up link" accessibilityHint="Tap to create a new account" onClick="signupTap">Sign Up</Label>
    </View>
  </Window>
</Alloy>
