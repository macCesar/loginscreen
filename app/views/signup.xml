<Alloy>
  <Window id="win">
		<View id="bgTop" class="bgTop"/>
		<View id="bgBottom" class="bgBottom"/>

		<View class="header">
			<Label id="backBtn" class="backBtn" onClick="goBack">← Back</Label>
		</View>

    <ScrollView id="scrollView" contentWidth="Ti.UI.FILL" showVerticalScrollIndicator="true">
      <View id="content">
				<Label class="screenIcon">🚀</Label>
				<Label id="screenTitle" class="screenTitle">Create Account</Label>
				<Label id="screenSubtitle" class="screenSubtitle">Fill in the details below to get started.</Label>

        <!-- Name -->
        <View id="nameGroup" class="fieldGroup">
					<Label id="nameLabel" class="fieldLabel">Full Name</Label>
          <TextField id="nameField" class="field" hintText="John Doe" autocapitalization="Ti.UI.TEXT_AUTOCAPITALIZATION_WORDS" returnKeyType="Ti.UI.RETURNKEY_NEXT" onReturn="focusEmail"/>
          <View id="nameUnderline" class="underline"/>
        </View>

        <!-- Email -->
        <View id="emailGroup" class="fieldGroup">
					<Label id="emailLabel" class="fieldLabel">Email</Label>
          <TextField id="emailField" class="field" hintText="you@example.com" keyboardType="Ti.UI.KEYBOARD_TYPE_EMAIL" autofillType="Ti.UI.AUTOFILL_TYPE_EMAIL" autocapitalization="Ti.UI.TEXT_AUTOCAPITALIZATION_NONE" autocorrect="false" returnKeyType="Ti.UI.RETURNKEY_NEXT" onReturn="focusPassword" onChange="validateEmail"/>
          <View id="emailUnderline" class="underline"/>
          <Label id="emailError" class="fieldError">Please enter a valid email address</Label>
        </View>

        <!-- Password -->
        <View id="passwordGroup" class="fieldGroup">
					<Label id="passwordLabel" class="fieldLabel">Password</Label>
          <TextField id="passwordField" class="field" hintText="Min. 8 characters" passwordMask="true" autofillType="Ti.UI.AUTOFILL_TYPE_NEW_PASSWORD" returnKeyType="Ti.UI.RETURNKEY_NEXT" onReturn="focusConfirm" onChange="validatePassword"/>
          <View id="passwordUnderline" class="underline"/>
          <Label id="passwordError" class="fieldError">Password must be at least 8 characters</Label>
        </View>

        <!-- Confirm Password -->
        <View id="confirmGroup" class="fieldGroup">
					<Label id="confirmLabel" class="fieldLabel">Confirm Password</Label>
          <TextField id="confirmField" class="field" hintText="Re-enter your password" passwordMask="true" autofillType="Ti.UI.AUTOFILL_TYPE_NEW_PASSWORD" returnKeyType="Ti.UI.RETURNKEY_DONE" onReturn="doSignup" onChange="validateConfirm"/>
          <View id="confirmUnderline" class="underline"/>
          <Label id="confirmError" class="fieldError">Passwords do not match</Label>
        </View>

        <!-- Sign Up Button -->
        <View id="signupBtn" class="primaryBtn" onClick="doSignup">
          <Label id="signupBtnLabel" class="primaryBtnLabel">Create Account</Label>
        </View>
        <ActivityIndicator id="loader" visible="false"/>

        <!-- Already have account -->
        <View id="loginRow">
          <Label id="loginText">Already have an account? </Label>
          <Label id="loginLink" onClick="goBack">Sign In</Label>
        </View>
      </View>
    </ScrollView>
  </Window>
</Alloy>
